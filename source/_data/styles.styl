* {
  box-sizing: border-box;
}

/* ========== 手机全屏消除留白 ========== */
@media screen and (max-width: 768px) {
  html, body {
    overflow-x: hidden;
  }
  .container {
    width: 100% !important;
    padding: 0 6px !important;
  }
  .main-inner {
    width: 100% !important;
  }
  .content-wrap {
    width: 100% !important;
    padding: 0 !important;
  }
  .sidebar {
    display: none !important;
  }
  .post-block {
    padding: 12px 8px !important;
  }
}

/* ========== 数学公式防溢出 ========== */
.MathJax_Display, .katex-display {
  overflow-x: auto;
  overflow-y: hidden;
  padding: 6px 0;
  max-width: 100%;
  transform-origin: left center;
}
.MathJax, .katex {
  max-width: 100%;
}
/* 滚动条美化 */
.MathJax_Display::-webkit-scrollbar,
.katex-display::-webkit-scrollbar {
  height: 4px;
}
.MathJax_Display::-webkit-scrollbar-thumb,
.katex-display::-webkit-scrollbar-thumb {
  background #cccccc;
  border-radius: 2px;
}